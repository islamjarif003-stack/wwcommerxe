                    { id: uuidv4(), sku: "WW-PNJ-001-L-WHT", attributes: { Size: "L", color: "white" }, price: 1200, stock: 15, isActive: true },
                    { id: uuidv4(), sku: "WW-PNJ-001-XL-BLU", attributes: { Size: "XL", Color: "Sky Blue" }, price: 1250, stock: 18, isActive: true },
