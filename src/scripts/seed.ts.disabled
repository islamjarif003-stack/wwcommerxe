                    "https://images.unsplash.com/photo-1506439773649-6e0eb8cfb237?w=600",
                ],
                basePrice: 35000,
                comparePrice: 42000,
                sku: "WW-FRN-001",
                stock: 8,
                lowStockThreshold: 2,
                attributes: { "Finish": ["Natural", "Dark Walnut", "Honey"] },
                variants: [],
                isActive: true, isFeatured: true, isDigital: false,
                rating: 4.6, reviewCount: 45, soldCount: 67, viewCount: 2300,
                demandScore: 55, performanceScore: 70,
            },
            {
                name: "Men's Cargo Pants",
                slug: "mens-cargo-pants",
                description: "Durable multi-pocket cargo pants. Comfortable fit, ideal for outdoor activities and casual wear.",
                shortDescription: "Multi-pocket durable cargo pants for men",
                categoryId: mensCat?.id,
                brand: "WW Casuals",
                tags: ["cargo", "pants", "men", "outdoor"],
                images: [
