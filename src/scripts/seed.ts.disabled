                ],
                basePrice: 1500,
                comparePrice: 2000,
                sku: "WW-CGO-001",
                stock: 3,
                lowStockThreshold: 5,
                attributes: { Size: ["28", "30", "32", "34", "36"], Color: ["Olive", "Black", "Tan", "Navy"] },
                variants: [],
                isActive: true, isFeatured: false, isDigital: false,
                rating: 4.2, reviewCount: 178, soldCount: 890, viewCount: 5600,
                demandScore: 68, performanceScore: 61,
            },
            {
                name: "Wireless Bluetooth Earbuds",
                slug: "wireless-bluetooth-earbuds",
                description: "True wireless earbuds with 30hrs battery life, active noise cancellation, IPX5 water resistance.",
