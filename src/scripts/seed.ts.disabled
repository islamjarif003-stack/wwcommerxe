                rating: 4.4, reviewCount: 312, soldCount: 1230, viewCount: 7800,
                demandScore: 85, performanceScore: 79,
            },
        ];

        products.forEach((p) => {
            db.insert("products", {
                id: uuidv4(),
                weight: 0.5,
                ...p,
                createdAt: new Date().toISOString(),
                updatedAt: new Date().toISOString(),
            } as never);
        });
        console.log("✅ Products seeded");
    }

    // ── Feature Flags ──────────────────────────────────────
    if (db.getAll("featureFlags").length === 0) {
        const flags = [
            { key: "ai_recommendations", name: "AI Product Recommendations", description: "Show AI-powered product suggestions", isEnabled: true, rolloutPercentage: 100, targetSegments: [] },
            { key: "flash_sale_banner", name: "Flash Sale Banner", description: "Show flash sale countdown banner", isEnabled: false, rolloutPercentage: 0, targetSegments: [] },
            { key: "loyalty_points", name: "Loyalty Points System", description: "Award points on every purchase", isEnabled: true, rolloutPercentage: 100, targetSegments: [] },
            { key: "express_checkout", name: "Express Checkout", description: "One-click checkout for returning customers", isEnabled: true, rolloutPercentage: 80, targetSegments: ["returning_customer"] },
            { key: "live_chat", name: "Live Chat Widget", description: "Show live chat support button", isEnabled: true, rolloutPercentage: 100, targetSegments: [] },
        ];
        flags.forEach((f) => db.insert("featureFlags", { id: uuidv4(), ...f, metadata: {}, createdAt: new Date().toISOString(), updatedAt: new Date().toISOString() }));
        console.log("✅ Feature flags seeded");
    }

    // ── Sample Orders ─────────────────────────────────────
    if (db.getAll("orders").length === 0) {
        const zones = db.getAll("deliveryZones");
        const products = db.getAll("products");
        const statuses = ["pending", "confirmed", "processing", "shipped", "delivered"];

        for (let i = 0; i < 15; i++) {
            const product = products[Math.floor(Math.random() * products.length)];
            const zone = zones[Math.floor(Math.random() * zones.length)];
            const status = statuses[Math.floor(Math.random() * statuses.length)] as any;
            const qty = Math.floor(Math.random() * 3) + 1;
            const subtotal = product.basePrice * qty;
            const deliveryCharge = 80;
            const total = subtotal + deliveryCharge;
            const daysAgo = Math.floor(Math.random() * 30);
            const createdAt = new Date(Date.now() - daysAgo * 86400000).toISOString();

            db.insert("orders", {
                id: uuidv4(),
                orderNumber: `WW26${String(i + 1).padStart(4, "0")}`,
                userId: undefined,
                customerName: ["Rahim Uddin", "Karim Hossain", "Fatema Begum", "Nasrin Akter", "Md. Jakir"][i % 5],
                customerEmail: `customer${i + 1}@example.com`,
                customerPhone: `0171${String(Math.random()).slice(2, 9)}`,
                shippingAddress: {
                    id: uuidv4(),
                    label: "Home",
                    name: "Rahim Uddin",
                    phone: "01711234567",
                    addressLine: `${i + 1}/A Lake View Road`,
                    city: "Dhaka",
                    district: "Dhaka",
                    zone: "Mirpur",
                    isDefault: true,
                },
                items: [{ productId: product.id, name: product.name, sku: product.sku, image: product.images[0], quantity: qty, unitPrice: product.basePrice, totalPrice: product.basePrice * qty }],
                subtotal,
                deliveryCharge,
                discount: 0,
                total,
                paymentMethod: "cod",
                paymentStatus: status === "delivered" ? "paid" : "pending",
                status,
                deliveryZoneId: zone.id,
                riskScore: Math.floor(Math.random() * 40),
                riskFlags: [],
                isFraudSuspect: false,
                statusHistory: [{ status: "pending", timestamp: createdAt }],
                createdAt,
                updatedAt: createdAt,
            } as never);
