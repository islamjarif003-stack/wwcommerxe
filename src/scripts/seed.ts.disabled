                slug: "xiaomi-redmi-note-13",
                description: "108MP camera, 5000mAh battery, AMOLED display. Officially sold in Bangladesh with warranty.",
                shortDescription: "108MP camera smartphone with AMOLED screen",
                categoryId: electronicsCat?.id,
                brand: "Xiaomi",
                tags: ["smartphone", "xiaomi", "redmi", "mobile"],
                images: [
                    "https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=600",
                    "https://images.unsplash.com/photo-1598327105666-5b89351aff97?w=600",
                ],
                basePrice: 22500,
                comparePrice: 25000,
                sku: "WW-PHN-001",
                stock: 45,
                lowStockThreshold: 5,
                attributes: { Storage: ["128GB", "256GB"], Color: ["Midnight Black", "Arctic White", "Ocean Blue"] },
                variants: [
                    { id: uuidv4(), sku: "WW-PHN-001-128-BLK", attributes: { Storage: "128GB", Color: "Midnight Black" }, price: 22500, stock: 15, isActive: true },
                    { id: uuidv4(), sku: "WW-PHN-001-256-WHT", attributes: { Storage: "256GB", Color: "Arctic White" }, price: 24500, stock: 10, isActive: true },
                ],
                isActive: true, isFeatured: true, isDigital: false,
                rating: 4.3, reviewCount: 89, soldCount: 234, viewCount: 4500,
