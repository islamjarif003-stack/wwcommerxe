import { db } from "../lib/db";
import { hashPassword } from "../lib/auth";
import { v4 as uuidv4 } from "uuid";

async function seed() {
    console.log("🌱 Seeding WW Commerce OS database...");

    // ── Admin User ──────────────────────────────────────────
    const existingAdmin = db.query("users", (u) => u.role === "superadmin")[0];
    if (!existingAdmin) {
        const hashedPwd = await hashPassword("Admin@1234");
        db.insert("users", {
            id: uuidv4(),
            name: "Super Admin",
            email: "admin@wwcommerce.com",
            password: hashedPwd,
            phone: "01700000000",
            role: "superadmin",
            isActive: true,
            emailVerified: true,
            addresses: [],
            wishlist: [],
            totalOrders: 0,
            totalSpent: 0,
            loyaltyPoints: 0,
            behaviorProfile: { segments: ["admin"], avgSessionDuration: 0, visitCount: 0, preferredCategories: [], conversionProbability: 0 },
            createdAt: new Date().toISOString(),
            updatedAt: new Date().toISOString(),
        });
        console.log("✅ Super Admin seeded: admin@wwcommerce.com / Admin@1234");
    }

    // ── Categories ─────────────────────────────────────────
    const cats = [
        { name: "Men's Fashion", slug: "mens-fashion", description: "Shirts, pants, jackets for men", sortOrder: 1, image: "https://images.unsplash.com/photo-1490114538077-0a7f8cb49891?w=400" },
        { name: "Women's Fashion", slug: "womens-fashion", description: "Saree, kurti, dress for women", sortOrder: 2, image: "https://images.unsplash.com/photo-1483985988355-763728e1935b?w=400" },
        { name: "Electronics", slug: "electronics", description: "Phones, laptops, accessories", sortOrder: 3, image: "https://images.unsplash.com/photo-1498049794561-7780e7231661?w=400" },
        { name: "Home & Living", slug: "home-living", description: "Furniture, decor, kitchen items", sortOrder: 4, image: "https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=400" },
        { name: "Grocery", slug: "grocery", description: "Fresh vegetables, rice, spices", sortOrder: 5, image: "https://images.unsplash.com/photo-1542838132-92c53300491e?w=400" },
        { name: "Beauty & Health", slug: "beauty-health", description: "Skincare, vitamins, cosmetics", sortOrder: 6, image: "https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=400" },
    ];

    if (db.getAll("categories").length === 0) {
        cats.forEach((c) => db.insert("categories", { id: uuidv4(), ...c, isActive: true, createdAt: new Date().toISOString(), updatedAt: new Date().toISOString() }));
        console.log("✅ Categories seeded");
    }

