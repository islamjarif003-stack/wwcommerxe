# ═══════════════════════════════════════════════════════════════
# WW Commerce — Environment Variables Template
# Copy this file to .env.local for development
# Copy to .env on your production server
# NEVER commit the actual .env file to git
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# Local development:
DATABASE_URL="postgresql://postgres:password@localhost:5432/wwcommerce?schema=public"
# Production (Railway / PlanetScale / Supabase / Neon / Self-hosted):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/wwcommerce?schema=public&sslmode=require"

# ── Authentication ────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET="CHANGE_THIS_TO_A_STRONG_64_CHAR_SECRET_openssl_rand_base64_64"
JWT_REFRESH_SECRET="CHANGE_THIS_TO_A_DIFFERENT_STRONG_64_CHAR_SECRET_openssl_rand_base64_64"
JWT_EXPIRES_IN="7d"

# Admin setup key (one-time use to create first superadmin)
ADMIN_SETUP_KEY="CHANGE_THIS_TO_A_STRONG_RANDOM_KEY"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="WW Commerce"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NODE_ENV="production"

# Set to true to automatically seed dummy products and categories on startup
# RUN_SEED="true"

# Comma-separated allowed origins for server actions
ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# ── Email (optional — for order confirmations) ────────────────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="WW Commerce <noreply@yourdomain.com>"

# ── File Storage (optional — for product images) ──────────────
# Cloudinary (recommended):
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# AWS S3:
# AWS_ACCESS_KEY_ID="your-key"
# AWS_SECRET_ACCESS_KEY="your-secret"
# AWS_REGION="ap-southeast-1"
# AWS_S3_BUCKET="wwcommerce-uploads"

# ── Payment (optional) ────────────────────────────────────────
# SSLCommerz (Bangladesh):
# SSLCOMMERZ_STORE_ID="your-store-id"
# SSLCOMMERZ_STORE_PASS="your-store-password"
# SSLCOMMERZ_IS_LIVE="false"

# bKash:
# BKASH_APP_KEY="your-key"
# BKASH_APP_SECRET="your-secret"
# BKASH_USERNAME="your-username"
# BKASH_PASSWORD="your-password"

# ── AI / Analytics (optional) ─────────────────────────────────
# OPENAI_API_KEY="sk-..."
# GEMINI_API_KEY="AIzaSy..."
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
